      <column caption='Month Order' datatype='integer' name='[Calculation_0774349382811648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Month]&#13;&#10;WHEN &quot;Apr&quot; THEN 1&#13;&#10;WHEN &quot;May&quot; THEN 2&#13;&#10;WHEN &quot;Jun&quot; THEN 3&#13;&#10;WHEN &quot;Jul&quot; THEN 4&#13;&#10;WHEN &quot;Aug&quot; THEN 5&#13;&#10;WHEN &quot;Sep&quot; THEN 6&#13;&#10;WHEN &quot;Oct&quot; THEN 7&#13;&#10;WHEN &quot;Nov&quot; THEN 8&#13;&#10;WHEN &quot;Dec&quot; THEN 9&#13;&#10;WHEN &quot;Jan&quot; THEN 10&#13;&#10;WHEN &quot;Feb&quot; THEN 11&#13;&#10;WHEN &quot;Mar&quot; THEN 12&#13;&#10;END' />
